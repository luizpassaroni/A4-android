<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:padding="8dp">

    <TextView
        android:id="@+id/nome_produto_carrinho"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/remover_item"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/remover_item"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/remover"
        app:icon="@drawable/ic_delete"
        app:iconGravity="textStart"
        app:iconPadding="4dp"
        app:iconTint="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subtotal_item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/decrementar_quantidade"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nome_produto_carrinho" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/decrementar_quantidade"
        style="@style/Widget.Material3.Button.IconButton.Outlined"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/diminuir"
        app:icon="@drawable/ic_remove"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="?attr/colorPrimary"
        app:layout_constraintEnd_toStartOf="@id/quantidade_produto"
        app:layout_constraintTop_toBottomOf="@id/remover_item" />

    <TextView
        android:id="@+id/quantidade_produto"
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:gravity="center"
        app:layout_constraintEnd_toStartOf="@id/incrementar_quantidade"
        app:layout_constraintTop_toTopOf="@id/decrementar_quantidade" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/incrementar_quantidade"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/aumentar"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="?attr/colorOnPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/decrementar_quantidade" />
</androidx.constraintlayout.widget.ConstraintLayout>
